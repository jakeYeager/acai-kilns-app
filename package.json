{
  "name": "acai-kilns-app",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first kiln firing logger for ACAI Studios & Gallery.",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore --project demo-acai-kilns 'vitest run tests/rules.test.ts'",
    "emulators": "firebase emulators:start --import=./.emulator-data --export-on-exit",
    "emulators:fresh": "firebase emulators:start",
    "seed:emulator": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GCLOUD_PROJECT=acai-kilns-dev node scripts/seed.mjs",
    "bootstrap-admin:emulator": "FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GCLOUD_PROJECT=acai-kilns-dev node scripts/bootstrap-admin.mjs"
  },
  "dependencies": {
    "@nuxt/ui": "^2.18.7",
    "@nuxtjs/turnstile": "^0.9.10",
    "@vite-pwa/nuxt": "^0.10.6",
    "firebase": "^11.0.1",
    "nuxt": "~3.19.0",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.7.4",
    "firebase-admin": "^12.6.0",
    "firebase-tools": "^13.22.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "vue-tsc": "^2.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
