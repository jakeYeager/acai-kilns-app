# Kiln Firing Logger — environment variables
#
# Copy this file to `.env` (gitignored) and fill in real values.
# `NUXT_PUBLIC_*` are exposed to the client bundle. Treat them as public.
# Everything else is server-only.

# --- Firebase web SDK config (public, ends up in the client bundle) ---
# Find these in the Firebase Console > Project Settings > Your apps.
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# --- App-level config ---
NUXT_PUBLIC_APP_URL=https://kilns.example.com
NUXT_PUBLIC_ENV=dev

# Set to "true" to point the app at the Firebase Local Emulator Suite
# instead of a real Firebase project. Used during local development.
NUXT_PUBLIC_USE_EMULATORS=true

# --- Cloudflare Turnstile ---
# Site key is public; secret key is NOT (server-side verification only).
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Local emulator development only ---
# NEVER commit a real service-account JSON. In production, Cloud Functions
# use the project's default service account.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.local.json

# ---------------------------------------------------------------------
# Cloud Function secrets — NOT in this file (or any committed file).
# Live in Secret Manager / Firebase Functions config:
#
#   SLACK_WEBHOOK_KILN_REPORTS    — scheduled report-link posts
#   SLACK_WEBHOOK_WEBAPP_ALERTS   — health alerts (shared w/ volunteer app)
#   SLACK_WEBHOOK_KILN_REPAIR     — problem reports
#
# Set with:
#   firebase functions:secrets:set SLACK_WEBHOOK_KILN_REPORTS
# ---------------------------------------------------------------------
